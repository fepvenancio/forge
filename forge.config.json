{
  "workers": {
    "max_parallel": 20
  },
  "cost": {
    "max_cycle_cost_usd": 50
  },
  "dolt": {
    "host": "localhost",
    "port": 3306,
    "database": "forge"
  },
  "docker": {
    "worker_image": "forge-worker:latest",
    "network": "none",
    "resources": {
      "memory": "2g",
      "cpus": "1.0",
      "note": "20 parallel workers × 2GB = 40GB peak. On laptops (16GB RAM) set max_parallel to 4 and memory to 1g."
    }
  }
}
